# Copy to backend/.env (NOT committed) and fill values.

# Azure Cognitive Services (OCR + TTS)
AZURE_VISION_KEY=
AZURE_VISION_ENDPOINT=
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=koreacentral

# Optional: if you use a dedicated endpoint instead of region
# AZURE_SPEECH_ENDPOINT=

# Optional
DB_PATH=mediclens.db

# IMPORTANT: Demo data is disabled by default (to avoid exposing samples to users).
# Only enable this for local development.
# ALLOW_DEMO_DATA=1

# Get your key from data.go.kr after applying for the MFDS OpenAPI you want.
MFDS_SERVICE_KEY=

# Optional overrides
MFDS_API_BASE=https://apis.data.go.kr

# IMPORTANT:
# You must set this to the exact '요청주소' path for the API you applied for on data.go.kr.
# Examples:
#   /1471000/DrbEasyDrugInfoService/getDrbEasyDrugList
#   /1471000/DrbEasyDrugInfoService
#   /1471000/DrugDmstPtntStusService/getDrugDmstPtntStusService
MFDS_SERVICE_PATH=

# Optional: which query field receives the `q` parameter in /mfds/search.
# Different APIs use different search fields (some have none).
# Set empty to disable server-side search param and fall back to substring filtering.
MFDS_SEARCH_PARAM=itemName

# Optional (separate API family): DUR/병용금기 데이터는 api.odcloud.kr 기반일 수 있습니다.
# ODCloud(OpenAPI) 공통 설정
# ODCLOUD_API_BASE=https://api.odcloud.kr/api
# Provide either serviceKey (query) or Authorization (header).
# ODCLOUD_SERVICE_KEY=
# ODCLOUD_AUTHORIZATION=

# DUR dataset path (example)
# DUR_SERVICE_PATH=/15089525/v1/uddi:3f2efdac-942b-494e-919f-8bdc583f65ea

# Pharmacy finder dataset path (set the dataset you have access to)
# PHARMACY_SERVICE_PATH=/15089525/v1/uddi:xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
