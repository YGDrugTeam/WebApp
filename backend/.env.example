# Copy to backend/.env (NOT committed) and fill values.
# Get your key from data.go.kr after applying for the MFDS OpenAPI you want.
MFDS_SERVICE_KEY=

# Optional overrides
MFDS_API_BASE=https://apis.data.go.kr

# IMPORTANT:
# You must set this to the exact '요청주소' path for the API you applied for on data.go.kr.
# Examples:
#   /1471000/DrbEasyDrugInfoService/getDrbEasyDrugList
#   /1471000/DrbEasyDrugInfoService
#   /1471000/DrugDmstPtntStusService/getDrugDmstPtntStusService
MFDS_SERVICE_PATH=

# Optional: which query field receives the `q` parameter in /mfds/search.
# Different APIs use different search fields (some have none).
# Set empty to disable server-side search param and fall back to substring filtering.
MFDS_SEARCH_PARAM=itemName

# Optional (separate API family): DUR/병용금기 데이터는 api.odcloud.kr 기반일 수 있습니다.
# If you later add DUR integration, these keys are commonly used:
# ODCLOUD_SERVICE_KEY=
# ODCLOUD_AUTHORIZATION=
